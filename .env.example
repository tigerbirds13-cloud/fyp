# Backend configuration
JWT_SECRET=replace_with_secure_secret
JWT_EXPIRES_IN=7d
MONGODB_URI=mongodb://localhost:27017/fyp
FRONTEND_URL=http://localhost:3000

# Frontend Google OAuth
# Must be a real client id ending with .apps.googleusercontent.com
REACT_APP_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# Optional email provider settings
SENDGRID_API_KEY=your_sendgrid_api_key
EMAIL_FROM=no-reply@example.com

# Khalti Payment Gateway
# Sandbox: use live_secret_key from https://test-admin.khalti.com
# Production: use live_secret_key from https://admin.khalti.com
KHALTI_SECRET_KEY=your_khalti_live_secret_key
KHALTI_PUBLIC_KEY=your_khalti_public_key
# Set NODE_ENV=production to use the production Khalti API endpoint
